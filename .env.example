# ============================================================
# CONFIGURACAO DO MIDDLEWARE UNIFICADO - Itau + CNP Ja
# ============================================================

# --- AUTENTICACAO UNIFICADA ---
# Uma unica API Key protege TODAS as rotas (Itau e CNP Ja)
MIDDLEWARE_API_KEY=gerar-uma-chave-secreta-super-forte-aqui

# --- PORTA ---
PORT=3000

# --- RATE LIMIT ---
RATE_LIMIT_PER_MINUTE=60

# --- DEBUG ---
DEBUG=false

# ============================================================
# ITAU - BOLETOS / PIX
# ============================================================

# Ambiente: sandbox ou producao
AMBIENTE=producao

# Credenciais OAuth2 Itau
ITAU_CLIENT_ID=seu-client-id-itau
ITAU_CLIENT_SECRET=seu-client-secret-itau

# PIX
ITAU_PIX_CHAVE=email@suaempresa.com.br

# Dados bancarios
ITAU_AGENCIA=7764
ITAU_CONTA=22338-9
ITAU_ID_BENEFICIARIO=776400223389
ITAU_CARTEIRA=109

# Certificados mTLS (producao) - coloque o conteudo PEM direto
ITAU_CERT_CRT=
ITAU_CERT_KEY=

# Mock mode (true para testar sem o Itau)
MOCK_MODE=false

# URLs customizadas (opcional - preenchidas automaticamente por AMBIENTE)
# ITAU_TOKEN_URL=https://sts.itau.com.br/api/oauth/token
# ITAU_BOLECODE_URL=https://api.itau.com.br/cash_management/v2
# ITAU_PIX_URL=https://api.itau.com.br/pix/v2

# ============================================================
# ODOO - XML-RPC Push
# ============================================================

ODOO_PUSH_ENABLED=true
ODOO_URL=https://seu-empresa.odoo.com
ODOO_DB=seu-empresa
ODOO_USERNAME=seu-email@empresa.com
ODOO_API_KEY=sua-api-key-do-odoo

# ============================================================
# CNP JA - CONSULTA CNPJ
# ============================================================

# Token da API comercial (opcional - sem ele usa API publica sem IE)
CNPJA_API_TOKEN=

# URL base (opcional - preenchida automaticamente baseado no token)
# CNPJA_API_BASE=https://api.cnpja.com

CNPJA_TIMEOUT=15000

# Token Consultar.IO para IE via SINTEGRA (opcional)
CONSULTAR_IO_TOKEN=